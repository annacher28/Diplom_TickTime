## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.user
*.suo
*.userprefs

# Build results
bin/
obj/

# Database files
*.db
*.db-shm
*.db-wal

# Visual Studio Code
.vscode/
*.code-workspace

# NuGet packages
packages/
*.nupkg