@model IEnumerable<WatchStore.Models.Order>

@{
    ViewData["Title"] = "Заказы";
}

<h1>Заказы</h1>

<table class="table">
    <thead>
        <tr>
            <th>№ заказа</th>
            <th>Пользователь</th>
            <th>Дата</th>
            <th>Сумма</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@(order.User?.FullName ?? order.User?.UserName)</td>
                <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.TotalAmount.ToString("C")</td>
                <td>@order.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@order.Id">Детали</a>
                </td>
            </tr>
        }
    </tbody>
</table>