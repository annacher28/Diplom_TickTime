@model IEnumerable<WatchStore.Models.Product>

@{
    ViewData["Title"] = "Избранное";
}

<h1>И ТУТ НИЧЕГО.</h1>

@if (!Model.Any())
{
    <p>...</p>
}
else
{
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)" class="card-img-top" alt="@product.Name">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Brand</p>
                        <p class="card-text"><strong>@product.Price.ToString("C")</strong></p>
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary">Подробнее</a>
                        <button class="btn btn-danger btn-sm remove-from-favorite" data-product-id="@product.Id">Удалить</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.remove-from-favorite').click(function() {
                var productId = $(this).data('product-id');
                $.post('/Catalog/RemoveFromFavorite', { productId: productId }, function() {
                    location.reload();
                });
            });
        });
    </script>
}