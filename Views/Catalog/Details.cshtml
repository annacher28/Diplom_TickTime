@model WatchStore.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

<div class="row">
    <div class="col-md-6">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)" class="img-fluid" alt="@Model.Name">
    </div>
    <div class="col-md-6">
        <h3>@Model.Brand</h3>
        <p>@Model.Description</p>
        <h4>@Model.Price.ToString("C")</h4>
        @if (User.Identity.IsAuthenticated)
        {
            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="form-group">
                    <label for="quantity">Количество</label>
                    <input type="number" name="quantity" value="1" min="1" class="form-control" style="width: 80px;" />
                </div>
                <button type="submit" class="btn btn-success">В корзину</button>
            </form>
        }
        else
        {
            <p><a asp-controller="Account" asp-action="Login">Войдите</a>, чтобы добавить в корзину.</p>
        }
        <a asp-action="Index" class="btn btn-secondary">Назад к каталогу</a>
    </div>
</div>